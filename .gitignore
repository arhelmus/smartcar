target/
__pycache__/
*.pyc
# native macOS build artifacts
.build/
server/third_party/openauto/build-macos/
# workspace-level Cargo.lock; we commit at server/ only
Cargo.lock
**/.DS_Store
.idea/
.vscode/
*.swp
server/certs/*.key
server/certs/*.crt
server/certs/*.pem
!server/certs/.gitkeep

# local environment (personal IPs, MACs — never commit)
.env.local

# init.py stamp — generated per clone, not committed
scripts/.init

# run_server detached-mode artifacts
.smartcar-server.pid
*.log

# ansible runtime cache (collections/roles/modules pulled to cwd, fact cache)
.ansible/
.ansible-lint-cache/
