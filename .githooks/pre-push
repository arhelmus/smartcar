#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

echo "pre-push: running fmt, clippy, tests, and audit in parallel…"

cargo fmt --all --check --manifest-path "$REPO_ROOT/server/Cargo.toml" \
    >"$REPO_ROOT/.githooks/.fmt.log" 2>&1 &
FMT_PID=$!

cargo clippy --all-targets --all-features --manifest-path "$REPO_ROOT/server/Cargo.toml" -- -D warnings \
    >"$REPO_ROOT/.githooks/.clippy.log" 2>&1 &
CLIPPY_PID=$!

cargo test --manifest-path "$REPO_ROOT/server/Cargo.toml" \
    >"$REPO_ROOT/.githooks/.test.log" 2>&1 &
TEST_PID=$!

cargo audit --file "$REPO_ROOT/server/Cargo.lock" \
    >"$REPO_ROOT/.githooks/.audit.log" 2>&1 &
AUDIT_PID=$!

FAILED=0

wait $FMT_PID    || { echo "ERROR: cargo fmt failed — run: cargo fmt --all --manifest-path server/Cargo.toml"; cat "$REPO_ROOT/.githooks/.fmt.log";    FAILED=1; }
wait $CLIPPY_PID || { echo "ERROR: cargo clippy failed:"; cat "$REPO_ROOT/.githooks/.clippy.log"; FAILED=1; }
wait $TEST_PID   || { echo "ERROR: cargo test failed:";   cat "$REPO_ROOT/.githooks/.test.log";   FAILED=1; }
wait $AUDIT_PID  || { echo "ERROR: cargo audit failed:";  cat "$REPO_ROOT/.githooks/.audit.log";  FAILED=1; }

rm -f "$REPO_ROOT/.githooks/.fmt.log" "$REPO_ROOT/.githooks/.clippy.log" "$REPO_ROOT/.githooks/.test.log" "$REPO_ROOT/.githooks/.audit.log"

[ $FAILED -eq 0 ] && echo "pre-push: all checks passed." || exit 1
