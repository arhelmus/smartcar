+namespace
+{
+// The projected stream is exactly this resolution; the window must match it
+// so Qt does 1:1 pixel mapping (no stretch, no resample blur) and so the
+// InputDevice's screen→video touch scaling stays consistent.
+QSize resolutionToSize(aap_protobuf::service::media::sink::message::VideoCodecResolutionType res)
+{
+    using Res = aap_protobuf::service::media::sink::message::VideoCodecResolutionType;
+    switch(res)
+    {
+    case Res::VIDEO_1280x720:  return QSize(1280, 720);
+    case Res::VIDEO_1920x1080: return QSize(1920, 1080);
+    default:                   return QSize(800, 480);
+    }
+}
+}
+
 QtVideoOutput::QtVideoOutput(configuration::IConfiguration::Pointer configuration)
     : VideoOutput(std::move(configuration))
     , playerReady_(false)
@@ -102,24 +120,24 @@ void QtVideoOutput::onStartPlayback()
 {
     OPENAUTO_LOG(info) << "[QtVideoOutput] onStartPlayback()";
     
+    // Size the window to the negotiated stream resolution. Anything else
+    // makes Qt rescale the frames (wrong aspect / blur) and desyncs the
+    // InputDevice touch mapping, which scales pointer coords by the ratio of
+    // the screen geometry to this video geometry.
+    const QSize videoSize = resolutionToSize(getVideoResolution());
+    OPENAUTO_LOG(info) << "[QtVideoOutput] Sizing window to negotiated resolution "
+                       << videoSize.width() << "x" << videoSize.height();
+
     videoWidget_->setAttribute(Qt::WA_OpaquePaintEvent, true);
     videoWidget_->setAttribute(Qt::WA_NoSystemBackground, true);
-    videoWidget_->setAspectRatioMode(Qt::IgnoreAspectRatio);
-    videoWidget_->setWindowFlags(Qt::Window | Qt::FramelessWindowHint);
-    
-    // Get the physical screen geometry and set widget to exactly match it
-    QScreen *screen = QGuiApplication::primaryScreen();
-    if (screen != nullptr) {
-        QRect screenGeometry = screen->geometry();
-        videoWidget_->setGeometry(screenGeometry);
-        OPENAUTO_LOG(info) << "[QtVideoOutput] Set video widget geometry to: " 
-                           << screenGeometry.width() << "x" << screenGeometry.height()
-                           << " at (" << screenGeometry.x() << "," << screenGeometry.y() << ")";
-    } else {
-        // Fallback to fullscreen if screen detection fails
-        videoWidget_->setFullScreen(true);
-        OPENAUTO_LOG(warning) << "[QtVideoOutput] Could not detect screen, using setFullScreen()";
-    }
+    // KeepAspectRatio: if the window manager can't honour the fixed size the
+    // frame letterboxes instead of distorting.
+    videoWidget_->setAspectRatioMode(Qt::KeepAspectRatio);
+    videoWidget_->setWindowFlags(Qt::Window);
+    videoWidget_->setWindowTitle("Android Auto");
+    // Fixed: the projected resolution is constant for the session, so the
+    // window must not drift from it.
+    videoWidget_->setFixedSize(videoSize);
     
     videoWidget_->raise();
     videoWidget_->show();
