# smartcar local environment — copy to .env.local and fill in your values.
# This file is checked in as a template; .env.local is git-ignored.

# ── Board SSH access ──────────────────────────────────────────────────────────
BOARD_HOST=10.55.0.1
BOARD_USER=root

# ── USB Ethernet link ─────────────────────────────────────────────────────────
# Host-side MAC the board's g_ether gadget advertises (host_addr in the
# board's /etc/modprobe.d/g_ether.conf). When the cable is plugged in, the
# laptop's USB-Ethernet interface adopts this MAC, so it's how the scripts
# pick the right interface out of macOS's rotating enX names.
BOARD_MAC=02:00:00:00:0a:02
