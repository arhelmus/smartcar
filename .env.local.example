# smartcar local environment — copy to .env.local and fill in your values.
# This file is checked in as a template; .env.local is git-ignored.

# ── Shared cargo build cache ──────────────────────────────────────────────────
# Point every checkout's `target/` at one shared dir so cargo / cross don't
# rebuild crates per-clone. `$HOME` and `~` are expanded by the loader.
CARGO_TARGET_DIR=$HOME/.cache/smartcar-target

# ── USB-Ethernet link IPs ─────────────────────────────────────────────────────
# Two ends of the same point-to-point USB-Ethernet link, paired in /24:
#   BOARD_HOST   = the board's IP   (fixed by the board's g_ether gadget)
#   LAPTOP_HOST  = the laptop's IP  (what assign_board_ip assigns to the
#                  laptop's USB-Ethernet interface so the board is reachable)
BOARD_HOST=10.55.0.1
LAPTOP_HOST=10.55.0.2

# ── Board SSH access ──────────────────────────────────────────────────────────
BOARD_USER=root

# ── USB Ethernet link ─────────────────────────────────────────────────────────
# Host-side MAC the board's g_ether gadget advertises (host_addr in the
# board's /etc/modprobe.d/g_ether.conf). When the cable is plugged in, the
# laptop's USB-Ethernet interface adopts this MAC, so it's how the scripts
# pick the right interface out of macOS's rotating enX names.
BOARD_MAC=02:00:00:00:0a:02
