# smartcar local environment — copy to .env.local and fill in your values.
# This file is checked in as a template; .env.local is git-ignored.

# ── Board SSH access ──────────────────────────────────────────────────────────
BOARD_HOST=10.55.0.1
BOARD_USER=root

# ── USB Ethernet MAC addresses ────────────────────────────────────────────────
# These come from /etc/modprobe.d/g_ether.conf on the board.
#   BOARD_USB_MAC  — board-side MAC (usb0 on the board)
#   LAPTOP_USB_MAC — laptop-side MAC (the interface the laptop sees)
# LAPTOP_USB_MAC is used to auto-detect the laptop's IP so --laptop-ip is
# optional in run_board.py.
BOARD_USB_MAC=02:00:00:00:0a:01
LAPTOP_USB_MAC=02:00:00:00:0a:02

# ── Optional overrides ────────────────────────────────────────────────────────
# Set LAPTOP_USB_IP to skip MAC-based auto-detection.
# LAPTOP_USB_IP=10.55.0.2
